// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Models ────────────────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String?  @unique
  description String?
  logoUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users              User[]
  eventOrganizations EventOrganization[]

  @@map("organizations")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?

  // ─── Tenant fields ───────────────────────────────────────────────
  orgId         String?                           // null only for super_admins
  role          String    @default("officer")     // "super_admin" | "org_admin" | "officer"
  title         String?                           // officer title (e.g. "Worship Leader")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  organization  Organization? @relation(fields: [orgId], references: [id])
  accounts      Account[]
  sessions      Session[]
  createdEvents Event[]       @relation("CreatedEvents")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Presentation {
  id           String   @id @default(cuid())
  title        String
  lyrics       String
  songQueue    Json     @default("[]")
  bgId         String   @default("deep-space")
  transitionId String   @default("fade")
  fontId       String   @default("inter")
  sizeId       String   @default("md")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Song {
  id        String   @id @default(cuid())
  title     String
  artist    String?
  lyrics    String?
  key       String? // e.g. "G", "A", "Bb"
  bpm       Int?
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceItems ServiceItem[]
}

model ServicePlan {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items ServiceItem[]
}

model ServiceItem {
  id        String   @id @default(cuid())
  order     Int
  type      ItemType
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  servicePlan   ServicePlan @relation(fields: [servicePlanId], references: [id])
  servicePlanId String

  song   Song?   @relation(fields: [songId], references: [id])
  songId String?
}

model MediaFile {
  id        String    @id @default(cuid())
  name      String
  url       String
  type      MediaType
  createdAt DateTime  @default(now())
}

/// Tracks daily AI search quota per organisation (keyed by a stable org identifier).
model AiSearchQuota {
  id        String   @id @default(cuid())
  /// Stable key identifying the organisation (e.g. "org_default" until multi-tenancy is wired).
  orgKey    String   @unique
  date      String /// ISO date string YYYY-MM-DD — resets when date changes.
  used      Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Event {
  id                   String       @id @default(cuid())
  title                String
  slug                 String       @unique
  description          String?      @db.Text
  type                 EventType
  venue                String?
  startDate            DateTime
  endDate              DateTime
  registrationDeadline DateTime?
  fee                  Float        @default(0)
  maxSlots             Int?
  status               EventStatus  @default(DRAFT)
  coverImage           String?
  createdBy            String
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  creator       User                @relation("CreatedEvents", fields: [createdBy], references: [id])
  organizations EventOrganization[]

  @@index([status, startDate])
  @@map("events")
}

model EventOrganization {
  id           String            @id @default(cuid())
  eventId      String
  orgId        String
  role         EventOrgRole      @default(HOST)
  inviteStatus EventInviteStatus @default(ACCEPTED)
  invitedBy    String?
  respondedAt  DateTime?
  createdAt    DateTime          @default(now())

  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id])

  @@unique([eventId, orgId])
  @@index([orgId, inviteStatus])
  @@map("event_organizations")
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum ItemType {
  SONG
  SCRIPTURE
  ANNOUNCEMENT
  MEDIA
  PRAYER
  OFFERING
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
}

enum EventType {
  CAMP
  FELLOWSHIP
  SEMINAR
  WORSHIP_NIGHT
}

enum EventStatus {
  DRAFT
  OPEN
  CLOSED
  CANCELLED
  COMPLETED
}

enum EventOrgRole {
  HOST
  COLLABORATOR
}

enum EventInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}
