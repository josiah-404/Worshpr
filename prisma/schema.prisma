// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Models ────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(MEDIA)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Presentation {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  lyrics       String
  bgId         String   @default("deep-space")
  transitionId String   @default("fade")
  fontId       String   @default("inter")
  sizeId       String   @default("md")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Song {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  artist    String?
  lyrics    String?
  key       String?  // e.g. "G", "A", "Bb"
  bpm       Int?
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceItems ServiceItem[]
}

model ServicePlan {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items ServiceItem[]
}

model ServiceItem {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  order         Int
  type          ItemType
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  servicePlan   ServicePlan @relation(fields: [servicePlanId], references: [id])
  servicePlanId String      @db.ObjectId

  song          Song?       @relation(fields: [songId], references: [id])
  songId        String?     @db.ObjectId
}

model MediaFile {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  url       String
  type      MediaType
  createdAt DateTime  @default(now())
}

/// Tracks daily AI search quota per organisation (keyed by a stable org identifier).
model AiSearchQuota {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  /// Stable key identifying the organisation (e.g. "org_default" until multi-tenancy is wired).
  orgKey    String   @unique
  date      String   /// ISO date string YYYY-MM-DD — resets when date changes.
  used      Int      @default(0)
  updatedAt DateTime @updatedAt
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MEDIA
}

enum ItemType {
  SONG
  SCRIPTURE
  ANNOUNCEMENT
  MEDIA
  PRAYER
  OFFERING
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
}
