// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Models ────────────────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String?  @unique
  description String?
  logoUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users              User[]
  eventOrganizations EventOrganization[]
  registrations      Registration[]
  orgFund            OrgFund?
  financeLedger      FinanceLedger[]

  @@map("organizations")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?

  // ─── Tenant fields ───────────────────────────────────────────────
  orgId         String?                           // null only for super_admins
  role          String    @default("officer")     // "super_admin" | "org_admin" | "officer"
  title         String?                           // officer title (e.g. "Worship Leader")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  organization          Organization? @relation(fields: [orgId], references: [id])
  accounts              Account[]
  sessions              Session[]
  createdEvents         Event[]         @relation("CreatedEvents")
  financeLedgerEntries  FinanceLedger[] @relation("LedgerEnteredBy")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Presentation {
  id           String   @id @default(cuid())
  title        String
  lyrics       String
  songQueue    Json     @default("[]")
  bgId         String   @default("deep-space")
  transitionId String   @default("fade")
  fontId       String   @default("inter")
  sizeId       String   @default("md")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Song {
  id        String   @id @default(cuid())
  title     String
  artist    String?
  lyrics    String?
  key       String? // e.g. "G", "A", "Bb"
  bpm       Int?
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceItems ServiceItem[]
}

model ServicePlan {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items ServiceItem[]
}

model ServiceItem {
  id        String   @id @default(cuid())
  order     Int
  type      ItemType
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  servicePlan   ServicePlan @relation(fields: [servicePlanId], references: [id])
  servicePlanId String

  song   Song?   @relation(fields: [songId], references: [id])
  songId String?
}

model MediaFile {
  id        String    @id @default(cuid())
  name      String
  url       String
  type      MediaType
  createdAt DateTime  @default(now())
}

/// Tracks daily AI search quota per organisation (keyed by a stable org identifier).
model AiSearchQuota {
  id        String   @id @default(cuid())
  /// Stable key identifying the organisation (e.g. "org_default" until multi-tenancy is wired).
  orgKey    String   @unique
  date      String /// ISO date string YYYY-MM-DD — resets when date changes.
  used      Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Event {
  id                   String       @id @default(cuid())
  title                String
  slug                 String       @unique
  description          String?      @db.Text
  type                 EventType
  venue                String?
  startDate            DateTime
  endDate              DateTime
  registrationDeadline DateTime?
  fee                  Float        @default(0)
  maxSlots             Int?
  status               EventStatus  @default(DRAFT)
  coverImage           String?
  createdBy            String
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  creator            User                @relation("CreatedEvents", fields: [createdBy], references: [id])
  organizations      EventOrganization[]
  registrationGroups RegistrationGroup[]
  registrations      Registration[]
  financeLedger      FinanceLedger[]

  @@index([status, startDate])
  @@map("events")
}

model Registrant {
  id                    String   @id @default(cuid())
  fullName              String
  nickname              String?
  email                 String   @unique
  phone                 String
  birthday              DateTime
  address               String   @db.Text
  church                String?
  organization          String?
  emergencyContactName  String
  emergencyContactPhone String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  registrations Registration[]

  @@map("registrants")
}

model RegistrationGroup {
  id               String   @id @default(cuid())
  eventId          String
  confirmationCode String   @unique
  submittedByName  String
  submittedByEmail String
  headcount        Int
  createdAt        DateTime @default(now())

  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations Registration[]
  sharedPayment Payment?       @relation("GroupPayment")

  @@index([eventId])
  @@map("registration_groups")
}

model Registration {
  id            String             @id @default(cuid())
  eventId       String
  registrantId  String
  groupId       String
  orgId         String
  status        RegistrationStatus @default(PENDING)
  paymentIntent PaymentIntent
  approvedBy    String?
  approvedAt    DateTime?
  rejectedBy    String?
  rejectedAt    DateTime?
  notes         String?            @db.Text
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  event        Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrant   Registrant        @relation(fields: [registrantId], references: [id])
  group        RegistrationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  organization Organization      @relation(fields: [orgId], references: [id])
  payment      Payment?          @relation("IndividualPayment")

  @@unique([eventId, registrantId])
  @@index([eventId, status])
  @@index([orgId, status])
  @@index([groupId])
  @@map("registrations")
}

model Payment {
  id            String        @id @default(cuid())
  amount        Float
  method        PaymentMethod
  receiptUrl    String?
  referenceNo   String?
  status        PaymentStatus @default(PENDING)
  verifiedBy    String?
  verifiedAt    DateTime?
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  registrationId String?       @unique
  registration   Registration? @relation("IndividualPayment", fields: [registrationId], references: [id])

  groupId String?            @unique
  group   RegistrationGroup? @relation("GroupPayment", fields: [groupId], references: [id])

  @@map("payments")
}

model EventOrganization {
  id           String            @id @default(cuid())
  eventId      String
  orgId        String
  role         EventOrgRole      @default(HOST)
  inviteStatus EventInviteStatus @default(ACCEPTED)
  invitedBy    String?
  respondedAt  DateTime?
  createdAt    DateTime          @default(now())

  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id])

  @@unique([eventId, orgId])
  @@index([orgId, inviteStatus])
  @@map("event_organizations")
}

model OrgFund {
  id             String   @id @default(cuid())
  orgId          String   @unique
  initialBalance Float    @default(0)
  currency       String   @default("PHP")
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])

  @@map("org_funds")
}

model FinanceLedger {
  id          String           @id @default(cuid())
  orgId       String
  eventId     String?
  type        FinanceEntryType
  category    FinanceCategory
  amount      Float
  description String
  referenceId    String?
  customCategory String?  @map("custom_category")
  payee          String?
  requestedBy    String?
  receiptUrl     String?
  enteredBy      String
  date        DateTime
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  organization  Organization @relation(fields: [orgId], references: [id])
  event         Event?       @relation(fields: [eventId], references: [id])
  enteredByUser User         @relation("LedgerEnteredBy", fields: [enteredBy], references: [id])

  @@index([orgId, type])
  @@index([orgId, date])
  @@index([eventId])
  @@map("finance_ledger")
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum ItemType {
  SONG
  SCRIPTURE
  ANNOUNCEMENT
  MEDIA
  PRAYER
  OFFERING
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
}

enum EventType {
  CAMP
  FELLOWSHIP
  SEMINAR
  WORSHIP_NIGHT
}

enum EventStatus {
  DRAFT
  OPEN
  CLOSED
  CANCELLED
  COMPLETED
}

enum EventOrgRole {
  HOST
  COLLABORATOR
}

enum EventInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PaymentIntent {
  CASH
  ONLINE
  FREE
}

enum PaymentMethod {
  CASH
  GCASH
  MAYA
  BANK_TRANSFER
  OTHER
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum FinanceEntryType {
  INCOME
  EXPENSE
}

enum FinanceCategory {
  // Income categories
  REGISTRATION
  OFFERTORY
  DONATION
  OTHER_INCOME
  // Expense categories
  PRIZES
  DESIGN_PRINTING
  FOOD_BEVERAGE
  TRANSPORTATION
  VENUE
  SUPPLIES
  MARKETING
  OTHER_EXPENSE
}
