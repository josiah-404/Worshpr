# Database
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# Google Gemini AI
GEMINI_API_KEY="your-gemini-api-key-here"

# Edge Store
EDGE_STORE_ACCESS_KEY="your-edgestore-access-key"
EDGE_STORE_SECRET_KEY="your-edgestore-secret-key"

# YouVersion Platform API (optional — adds extra online translations e.g. NIV; KJV, ESV, and MBBTAG12 are bundled offline)
# Get your key at https://developers.youversion.com
YOUVERSION_API_KEY=""
